# x-skill configuration
# Place this file at ~/.x-skill/.env
# Environment variables override values set here.

# Language: en | zh (prompted on first run)
# LANGUAGE=en

# GitHub API authentication (higher rate limit)
# GITHUB_TOKEN=
# GH_TOKEN=

# Custom agent directories
# CODEX_HOME=
# CLAUDE_CONFIG_DIR=

# Custom lock file location
# XDG_STATE_HOME=

# Skills API URL
# SKILLS_API_URL=https://skills.sh

# Include internal skills in discovery
# INSTALL_INTERNAL_SKILLS=false

# Disable telemetry
# DISABLE_TELEMETRY=
# DO_NOT_TRACK=
